# Weblate 环境变量模板
# 复制为 .env 并填入实际值,然后通过 `docker compose --env-file .env up -d` 启动
#
# 所有标 ? 的变量必须设置,否则 Weblate 不会启动。

# ============ 必需 ============

# Django secret key(运行 `openssl rand -hex 32` 生成)
WEBLATE_SECRET_KEY=

# Weblate 超级管理员密码(首次登录后建议修改)
WEBLATE_ADMIN_PASSWORD=

# 数据库密码(运行 `openssl rand -hex 16` 生成)
POSTGRES_PASSWORD=

# GitHub bot 账号 Personal Access Token(scopes: repo, write:org)
GITHUB_BOT_TOKEN=

# GitHub webhook secret(任意强随机字符串,与 GitHub 端配置一致)
GITHUB_WEBHOOK_SECRET=

# ============ 推荐 ============

# 站点对外域名
WEBLATE_SITE_DOMAIN=weblate.airbyte.internal

# 管理员邮箱(收告警)
WEBLATE_ADMIN_EMAIL=i18n-owner@airbyte.io

# 启用 HTTPS(0/1,生产建议 1)
WEBLATE_ENABLE_HTTPS=0

# 允许访问的主机(CIDR 或域名,逗号分隔)
WEBLATE_ALLOWED_HOSTS=*

# GitHub bot 用户名(用于 commit)
GITHUB_BOT_USER=airbyte-i18n-bot

# ============ SMTP 邮件 ============

SMTP_HOST=smtp.gmail.com
SMTP_USER=i18n-bot@airbyte.io
SMTP_PASSWORD=

# ============ 备份/监控(可选) ============

# Sentry DSN(用于错误上报)
# WEBLATE_SENTRY_DSN=

# Matomo/Plausible ID
# WEBLATE_MATOMO_URL=
# WEBLATE_MATOMO_ID=
